# ──────────────────────────────────────────────────────────────
# Blanchisserie SN — API
# Copier ce fichier en `.env` puis remplir les valeurs.
# ──────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
LOG_PRETTY=true

# CORS — origines autorisees, séparées par virgules
CORS_ORIGINS=http://localhost:5173,http://localhost:8081,exp://192.168.1.1:8081

# Database (Postgres)
DATABASE_URL=postgresql://blanchisserie:blanchisserie@localhost:5432/blanchisserie?schema=public

# JWT — generer 2 secrets long avec: openssl rand -base64 64
JWT_ACCESS_SECRET=changez_moi_avec_openssl_rand_base64_64
JWT_REFRESH_SECRET=changez_moi_aussi_avec_un_secret_different
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Argon2 (password hashing)
ARGON_MEMORY_COST=19456
ARGON_TIME_COST=2
ARGON_PARALLELISM=1

# Groq AI — recuperer un cle sur https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_MS=10000

# Upload uploads (photos, signatures)
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# Notifications
ENABLE_EMAIL=false
ENABLE_PUSH=false
ENABLE_SMS=false
