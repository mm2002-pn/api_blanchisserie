// ──────────────────────────────────────────────────────────────────────
//  BLANCHISSERIE SN — Prisma schema
//  Modèle de données end-to-end (mobile + web admin + AI)
// ──────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════ AUTH & USERS ════════════

enum Role {
  admin
  manager
  supervisor
  operator
  driver
  hotel
}

enum DriverAvailability {
  available     // disponible, pret a prendre une tournee
  on_route      // en tournee active
  off_duty      // fin de service
  unavailable   // conge / maladie / indispo
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?
  passwordHash  String
  firstName     String
  lastName      String
  role          Role
  isActive      Boolean   @default(true)
  // Disponibilite chauffeur (utile uniquement si role = driver).
  driverStatus  DriverAvailability? @default(available)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  clientId          String?         // si role = hotel
  client            Client?         @relation(fields: [clientId], references: [id])
  refreshTokens     RefreshToken[]
  pushTokens        UserPushToken[]
  auditLogs         AuditLog[]
  collectionsAsDrv  Order[]         @relation("DriverCollect")
  deliveriesAsDrv   Order[]         @relation("DriverDeliver")
  enrolledOnVehicles Vehicle[]      @relation("VehicleEnrolledDriver")
  enrollmentHistory  VehicleEnrollment[] @relation("EnrollmentDriver")

  @@index([role, isActive])
  @@index([clientId])
}

model UserPushToken {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token         String    @unique  // ex. ExponentPushToken[xxxxx]
  platform      String    // ios | android | web
  deviceName    String?
  isActive      Boolean   @default(true)
  lastUsedAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, isActive])
}

model RefreshToken {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  revokedAt   DateTime?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ════════════ CLIENTS ════════════

enum ClientType {
  hotel_5_etoiles
  hotel_4_etoiles
  hotel_3_etoiles
  restaurant
  autre
}

enum BillingPeriodicity {
  per_order   // facture émise dès la livraison de la commande
  monthly     // factures groupées en fin de mois
}

model Client {
  id              String     @id @default(cuid())
  name            String
  type            ClientType
  address         String
  city            String     @default("Dakar")
  contactPerson   String?
  phone           String?
  email           String?
  ninea           String?    // identifiant fiscal Sénégal
  geoLat          Float?
  geoLng          Float?
  tariffId        String?
  tariff          Tariff?    @relation(fields: [tariffId], references: [id])
  // Mode de facturation : par commande livree (defaut) ou groupee mensuelle.
  billingMode     BillingPeriodicity @default(per_order)
  isActive        Boolean    @default(true)
  notes           String?    @db.Text
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  users           User[]
  orders          Order[]
  invoices        Invoice[]
  creditNotes     CreditNote[]

  @@index([type, isActive])
}

// ════════════ CATALOGUE SERVICES ════════════

model Service {
  id          String   @id @default(cuid())
  code        String   @unique // ex: "blanchisserie", "nettoyage", "aqua_clean"
  label       String              // ex: "Blanchisserie", "Nettoyage à sec"
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ════════════ CATALOGUE LINGE ════════════

enum LinenCategory {
  LP    // Linge Plat
  LF    // Linge Forme
  NAE   // Nettoyage à sec
}

// Configuration affichage des catégories de linge (label FR + emoji + ordre).
// Codes fixes (FK enum). Seuls label / emoji / sortOrder / isActive sont editables.
// Permet a l'admin de renommer "Linge Plat" -> "Draps & taies" sans toucher au code.
model LinenCategoryConfig {
  id        String        @id @default(cuid())
  code      LinenCategory @unique
  label     String
  emoji     String?
  sortOrder Int           @default(0)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum BillingMode {
  weight    // au kilo
  piece     // à la pièce
}

model LinenType {
  id              String        @id @default(cuid())
  code            String        @unique
  name            String
  category        LinenCategory
  averageWeight   Int           // grammes
  billingMode     BillingMode
  unitPrice       Decimal       @db.Decimal(10, 2)
  treatmentMinutes Int?
  notes           String?
  // URL relative ou absolue de l'image affichee (mobile catalogue + back-office).
  // Renseignee par upload via /uploads/linen-type-images.
  imageUrl        String?
  // Pipeline de production par-type (etapes ordonnees).
  // Valeurs valides : lavage / sechage / calandrage / repassage / finition.
  pipeline        String[]      @default([])
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  triageItems     TriageItem[]
  tags            ItemTag[]
  invoiceLines    InvoiceLine[]

  @@index([category])
}

// ════════════ MACHINES & PROGRAMMES ════════════

enum MachineKind {
  laveuse
  secheuse
  calandre
  presse
  secheuse_repasseuse
}

enum MachineStatus {
  active
  maintenance
  hors_service
}

model Machine {
  id              String        @id @default(cuid())
  reference       String        @unique
  brand           String
  model           String
  kind            MachineKind
  capacityKg      Int
  location        String
  status          MachineStatus @default(active)
  lastMaintenanceAt DateTime?
  nextMaintenanceAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  batches         Batch[]

  @@index([kind, status])
}

model WashingProgram {
  id              String        @id @default(cuid())
  code            String        @unique
  name            String
  temperature     Int           // °C
  durationMin     Int
  spinSpeed       Int           // rpm
  waterLiters     Int
  detergentType   String
  suitable        LinenCategory[]
  description     String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  batches         Batch[]

  @@index([isActive])
}

// ════════════ COMMANDES & WORKFLOW ════════════

enum OrderStatus {
  pending           // créée par hotel, pas encore confirmée
  confirmed         // confirmée par admin
  collection_planned
  collected         // ramassé par chauffeur
  received          // réceptionné + pesé en atelier
  triaged           // ventilation par type effectuée
  in_production     // batches en cours
  ready             // prêt pour livraison
  delivered         // livré
  invoiced          // facturé
  cancelled
}

enum WorkflowState {
  COLLECTE_SCHEDULED
  COLLECTE_IN_PROGRESS
  COLLECTE_COMPLETED
  RECEPTION_PENDING
  WEIGHING_IN_PROGRESS
  WEIGHING_COMPLETED
  TRIAGE_PENDING
  TRIAGE_IN_PROGRESS
  TRIAGE_COMPLETED
  LAVAGE_PENDING
  LAVAGE_IN_PROGRESS
  LAVAGE_COMPLETED
  SECHAGE_PENDING
  SECHAGE_IN_PROGRESS
  SECHAGE_COMPLETED
  CALANDRAGE_PENDING
  CALANDRAGE_IN_PROGRESS
  CALANDRAGE_COMPLETED
  REPASSAGE_PENDING
  REPASSAGE_IN_PROGRESS
  REPASSAGE_COMPLETED
  FINITION_PENDING
  FINITION_IN_PROGRESS
  FINITION_COMPLETED
  LIVRAISON_SCHEDULED
  LIVRAISON_IN_PROGRESS
  LIVRAISON_COMPLETED
  CANCELLED
}

model Order {
  id                String        @id @default(cuid())
  orderNumber       String        @unique
  clientId          String
  client            Client        @relation(fields: [clientId], references: [id])

  status            OrderStatus   @default(pending)
  workflowState     WorkflowState @default(COLLECTE_SCHEDULED)

  // Estimation par le client
  estimatedItems    Json          // [{ category, type, quantity }]
  estimatedWeight   Int?          // grammes
  estimatedPriceFcfa Decimal?     @db.Decimal(12, 2)

  // Pesée chauffeur (terrain)
  driverWeight      Int?          // grammes
  driverPieces      Int?
  // Détail par type validé par le chauffeur : [{ type, quantity }]
  driverItems       Json?
  visualEstimation  String?       // S/M/L/XL
  collectionPhotos  String[]      // URLs

  // Pesée atelier (officielle = base facturation)
  receivedWeight    Int?          // grammes
  receivedPieces    Int?
  // Détail par type comptabilisé à la pesée atelier : [{ type, quantity }]
  receivedItems     Json?
  weightDeviation   Float?        // % calculé

  // Localisation cible de collecte (renseignée par le client à la création).
  // Utilisée par le chauffeur pour la navigation (deeplink maps).
  pickupGeoLat      Float?
  pickupGeoLng      Float?

  // Dates clés
  collectionDate    DateTime
  collectionPlannedAt DateTime?
  collectedAt       DateTime?
  receivedAt        DateTime?
  triagedAt         DateTime?
  readyAt           DateTime?
  deliveredAt       DateTime?

  // Affectations chauffeurs
  collectionDriverId String?
  collectionDriver   User?        @relation("DriverCollect", fields: [collectionDriverId], references: [id])
  collectionVehicleId String?
  collectionVehicle  Vehicle?     @relation("CollectVehicle", fields: [collectionVehicleId], references: [id])
  collectionPdaId    String?
  collectionPda      Pda?         @relation("CollectPda", fields: [collectionPdaId], references: [id])
  // Tournee de collecte groupee (plusieurs commandes regroupees sur un meme vehicule).
  collectionRoundId  String?
  collectionRound    CollectionRound? @relation("CollectRound", fields: [collectionRoundId], references: [id])
  // Timestamp de retour usine après collecte : marque que le chauffeur a
  // physiquement déposé les sacs à l'atelier. Sert de gate avant la pesée.
  unloadedAt         DateTime?
  // Tournee de livraison groupee (commandes livrees ensemble apres production).
  deliveryRoundId    String?
  deliveryRound      CollectionRound? @relation("DeliveryRound", fields: [deliveryRoundId], references: [id])
  collectionGeoLat   Float?
  collectionGeoLng   Float?
  collectionSignatureUrl String?
  collectionRecipientName String?

  deliveryDriverId  String?
  deliveryDriver    User?         @relation("DriverDeliver", fields: [deliveryDriverId], references: [id])
  deliveryVehicleId String?
  deliveryVehicle   Vehicle?      @relation("DeliverVehicle", fields: [deliveryVehicleId], references: [id])
  deliveryPdaId     String?
  deliveryPda       Pda?          @relation("DeliverPda", fields: [deliveryPdaId], references: [id])
  deliveryPhotos    String[]
  deliverySignatureUrl String?
  deliveryRecipientName String?

  instructions      String?       @db.Text
  cancelReason      String?

  // Versionnement optimistic locking
  version           Int           @default(0)

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  triage            TriageRecord?
  itemTags          ItemTag[]
  invoiceLines      InvoiceLine[]
  batchContributions BatchContributor[]

  @@index([clientId, status])
  @@index([workflowState])
  @@index([collectionDate])
}

// ════════════ VEHICULES ════════════

enum VehicleStatus {
  available
  in_route
  maintenance
  out_of_service
}

model Vehicle {
  id              String        @id @default(cuid())
  matricule       String        @unique
  brand           String
  model           String
  capacityKg      Int
  fuelLevel       Int           @default(100)
  status          VehicleStatus @default(available)
  lastMaintenanceAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Enrollement courant (cache denormalise pour lookup rapide).
  // L'historique complet est dans VehicleEnrollment (start/end dates).
  enrolledDriverId  String?
  enrolledDriver    User?       @relation("VehicleEnrolledDriver", fields: [enrolledDriverId], references: [id])
  enrolledPdaId     String?
  enrolledPda       Pda?        @relation("VehicleEnrolledPda", fields: [enrolledPdaId], references: [id])
  enrolledSince     DateTime?   // debut de l'enrollement courant

  collectOrders   Order[]       @relation("CollectVehicle")
  deliverOrders   Order[]       @relation("DeliverVehicle")
  enrollments     VehicleEnrollment[]
  collectionRounds CollectionRound[]

  @@index([status])
}

// ════════════ TOURNEE DE COLLECTE ════════════

enum CollectionRoundStatus {
  planned       // tournee creee, commandes affectees, pas encore demarree
  in_progress   // chauffeur a demarre la tournee
  completed     // toutes les commandes de la tournee ont ete collectees
  cancelled     // annulee, commandes liberees
}

// Type de tournee : collecte chez le client OU livraison chez le client.
// Une tournee = un trajet, soit pour ramasser (collect) soit pour deposer (delivery).
enum RoundType {
  collect
  delivery
}

// Tournee de collecte : ensemble de commandes groupees sur un meme vehicule
// pour une date+heure donnees. Un round = un trajet.
// Pattern : on cree un round avec plusieurs commandes, l'equipage (chauffeur+PDA)
// est derive de l'enrollement du vehicule, toutes les commandes passent en
// collection_planned d'un coup.
model CollectionRound {
  id              String                @id @default(cuid())
  number          String                @unique             // RND-YYYY-NNN
  type            RoundType             @default(collect)   // collect = ramassage, delivery = livraison
  vehicleId       String
  vehicle         Vehicle               @relation(fields: [vehicleId], references: [id])
  plannedAt       DateTime              // date+heure de demarrage prevu
  status          CollectionRoundStatus @default(planned)
  notes           String?
  startedAt       DateTime?
  completedAt     DateTime?
  // Arrivee usine (rounds collecte uniquement) : timestamp ou le chauffeur
  // a deposer les sacs a l'atelier. Debloque la pesee cote atelier.
  unloadedAt           DateTime?
  // Signature du receptionnaire atelier qui confirme l'arrivee des sacs.
  unloadedSignatureUrl String?
  unloadedRecipientName String?
  cancelledAt     DateTime?
  cancelReason    String?
  createdById     String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  // Relations explicites : un round est soit "collect" (orders via collectionRoundId)
  // soit "delivery" (orders via deliveryRoundId), determinee par `type`.
  collectOrders   Order[]               @relation("CollectRound")
  deliveryOrders  Order[]               @relation("DeliveryRound")

  @@index([status])
  @@index([type])
  @@index([vehicleId])
  @@index([plannedAt])
}

// Historique des enrollements (crew binding) d'un vehicule.
// Une seule ligne "active" par vehicule (endsAt IS NULL).
// Quand on cree un nouvel enrollement, on cloture l'ancien (endsAt = now).
model VehicleEnrollment {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId    String?
  driver      User?    @relation("EnrollmentDriver", fields: [driverId], references: [id])
  pdaId       String?
  pda         Pda?     @relation("EnrollmentPda", fields: [pdaId], references: [id])
  startsAt    DateTime
  endsAt      DateTime?
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([vehicleId, endsAt])
  @@index([driverId])
  @@index([pdaId])
}

// ════════════ PDA (handheld devices terrain) ════════════

enum PdaStatus {
  available
  in_use
  maintenance
  out_of_service
}

// Personal Digital Assistant : terminal portable utilise par les chauffeurs
// pour scanner les sacs, signer les bons et synchroniser la commande.
// Le lien chauffeur passe par Vehicle.enrolledPdaId (pattern enrollement).
model Pda {
  id              String     @id @default(cuid())
  reference       String     @unique     // ex. PDA-001 ou n° de serie
  brand           String?
  model           String?
  status          PdaStatus  @default(available)
  batteryLevel    Int?       // 0-100
  lastSyncAt      DateTime?
  isActive        Boolean    @default(true)
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  collectOrders   Order[]    @relation("CollectPda")
  deliverOrders   Order[]    @relation("DeliverPda")
  enrolledOnVehicles Vehicle[] @relation("VehicleEnrolledPda")
  enrollmentHistory VehicleEnrollment[] @relation("EnrollmentPda")

  @@index([status])
}

// ════════════ TRIAGE & ÉTIQUETAGE ════════════

model TriageRecord {
  id              String    @id @default(cuid())
  orderId         String    @unique
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  totalPieces     Int
  totalWeight     Int       // grammes
  deviationPct    Float     // vs receivedWeight
  performedBy     String    // userId
  performedAt     DateTime  @default(now())
  labelsPrinted   Boolean   @default(false)
  labelsPrintedAt DateTime?

  items           TriageItem[]

  @@index([performedBy])
}

model TriageItem {
  id              String    @id @default(cuid())
  triageId        String
  triage          TriageRecord @relation(fields: [triageId], references: [id], onDelete: Cascade)
  linenTypeId     String
  linenType       LinenType    @relation(fields: [linenTypeId], references: [id])
  pieces          Int
  weight          Int          // grammes

  @@index([triageId])
}

// Tag = 1 article individuel = traçabilité unitaire dans le batching multi-clients
enum ItemTagState {
  triaged
  in_lavage
  in_sechage
  in_calandrage
  in_repassage
  in_finition
  done
  lost
}

model ItemTag {
  id              String        @id @default(cuid())
  tag             String        @unique  // ex. CMD-141-001
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  linenTypeId     String
  linenType       LinenType     @relation(fields: [linenTypeId], references: [id])
  weight          Int           // grammes (estimé via averageWeight)
  state           ItemTagState  @default(triaged)
  currentBatchId  String?
  currentBatch    Batch?        @relation(fields: [currentBatchId], references: [id])
  scannedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  scans           TagScan[]

  @@index([orderId])
  @@index([state])
  @@index([currentBatchId])
}

model TagScan {
  id              String    @id @default(cuid())
  tagId           String
  tag             ItemTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  station         String    // ex. "lavage-A", "calandre-1"
  scannedBy       String    // userId
  scannedAt       DateTime  @default(now())
  metadata        Json?

  @@index([tagId])
}

// ════════════ BATCHES (cycles machine multi-clients) ════════════

enum BatchStage {
  lavage
  sechage
  calandrage
  repassage
  finition
}

enum BatchStatus {
  suggested      // proposé par bin-packing IA
  validated      // confirmé par superviseur
  in_progress
  completed
  cancelled
}

model Batch {
  id              String       @id @default(cuid())
  code            String       @unique  // ex. B-0408
  stage           BatchStage
  status          BatchStatus  @default(suggested)
  priority        Boolean      @default(false)

  machineId       String
  machine         Machine      @relation(fields: [machineId], references: [id])
  programId       String?
  program         WashingProgram? @relation(fields: [programId], references: [id])

  capacity        Int          // kg ou pcs selon stage
  currentLoad     Int          @default(0)
  utilization     Float        @default(0)

  estimatedDurationMin Int
  startedAt       DateTime?
  estimatedEndAt  DateTime?
  completedAt     DateTime?

  // Consommation effective
  actualWaterL    Int?
  actualEnergyKwh Int?

  // Source de la suggestion
  suggestedByAi   Boolean      @default(false)
  aiScore         Float?
  aiRationale     String?      @db.Text

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  contributors    BatchContributor[]
  itemTags        ItemTag[]

  @@index([stage, status])
  @@index([machineId])
}

// Lien batch ↔ client (un batch = N contributors)
model BatchContributor {
  id              String       @id @default(cuid())
  batchId         String
  batch           Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  orderId         String
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pieces          Int
  weight          Int          // grammes

  @@unique([batchId, orderId])
  @@index([orderId])
}

// ════════════ TARIFFS & FACTURES ════════════

enum TariffType {
  standard
  premium
  forfait
  segment
  service
}

model Tariff {
  id              String       @id @default(cuid())
  code            String       @unique
  name            String
  type            TariffType
  description     String?
  isDefault       Boolean      @default(false)
  isActive        Boolean      @default(true)
  validFrom       DateTime
  validUntil      DateTime?

  // Forfait
  monthlyPriceFcfa Decimal?    @db.Decimal(12, 2)
  monthlyKgLimit  Int?
  overagePerKgFcfa Decimal?    @db.Decimal(10, 2)

  applicableClientTypes ClientType[]

  items           TariffItem[]
  clients         Client[]
  invoices        Invoice[]

  @@index([isActive])
}

model TariffItem {
  id              String       @id @default(cuid())
  tariffId        String
  tariff          Tariff       @relation(fields: [tariffId], references: [id], onDelete: Cascade)
  linenTypeCode   String
  linenTypeName   String
  pricePerKg      Decimal?     @db.Decimal(10, 2)
  pricePerPiece   Decimal?     @db.Decimal(10, 2)
  billingMode     BillingMode

  @@index([tariffId])
}

enum InvoiceStatus {
  draft
  pending
  paid
  overdue
  cancelled
}

model Invoice {
  id              String       @id @default(cuid())
  invoiceNumber   String       @unique
  clientId        String
  client          Client       @relation(fields: [clientId], references: [id])
  tariffId        String?
  tariff          Tariff?      @relation(fields: [tariffId], references: [id])

  periodStart     DateTime
  periodEnd       DateTime
  invoiceDate     DateTime     @default(now())
  dueDate         DateTime
  paidDate        DateTime?

  subtotalFcfa    Decimal      @db.Decimal(14, 2)
  taxRate         Decimal      @db.Decimal(5, 4)  // ex. 0.18
  taxAmountFcfa   Decimal      @db.Decimal(14, 2)
  totalFcfa       Decimal      @db.Decimal(14, 2)
  paidAmountFcfa  Decimal?     @db.Decimal(14, 2)
  paymentMethod   String?

  status          InvoiceStatus @default(draft)
  pdfUrl          String?
  notes           String?      @db.Text

  // Versionnement optimistic locking
  version         Int          @default(0)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  lines           InvoiceLine[]

  @@index([clientId, status])
  @@index([dueDate])
}

model InvoiceLine {
  id              String       @id @default(cuid())
  invoiceId       String
  invoice         Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  orderId         String?
  order           Order?       @relation(fields: [orderId], references: [id])
  linenTypeId     String?
  linenType       LinenType?   @relation(fields: [linenTypeId], references: [id])
  description     String
  quantity        Int
  weight          Int?         // grammes
  unitPriceFcfa   Decimal      @db.Decimal(10, 2)
  totalFcfa       Decimal      @db.Decimal(14, 2)

  @@index([invoiceId])
}

// ════════════ AUDIT LOG ════════════

enum AuditAction {
  create
  update
  delete
  login
  logout
  permission
  scan
  weigh
  sign
  print
  ai_suggest
  ai_validate
}

model AuditLog {
  id              String       @id @default(cuid())
  at              DateTime     @default(now())
  actorId         String?
  actor           User?        @relation(fields: [actorId], references: [id])
  action          AuditAction
  entity          String       // ex. "order", "batch", "invoice"
  entityId        String?
  payload         Json?
  device          String?      // mobile / web / iot
  ipAddress       String?
  userAgent       String?
  geoLat          Float?
  geoLng          Float?

  @@index([entity, entityId])
  @@index([actorId])
  @@index([at])
}

// ════════════ NOTIFICATIONS ════════════

enum NotificationChannel {
  email
  push
  sms
}

enum NotificationStatus {
  queued
  sent
  failed
}

model Notification {
  id              String              @id @default(cuid())
  recipientUserId String?
  recipientEmail  String?
  recipientPhone  String?
  channel         NotificationChannel
  subject         String?
  body            String              @db.Text
  status          NotificationStatus  @default(queued)
  sentAt          DateTime?
  error           String?
  metadata        Json?
  createdAt       DateTime            @default(now())

  @@index([status, channel])
  @@index([recipientUserId])
}

// ════════════ DOCUMENTS COMMERCIAUX ════════════

enum DocumentType {
  BON_COMMANDE
  BON_COLLECTE
  BORDEREAU_TRIAGE
  BON_LIVRAISON
  FACTURE
  AVOIR
}

// Compteur sequentiel par type et par annee : produit les numeros
// CMD-2026-001, BCOL-2026-001, BL-2026-001, AV-2026-001, etc.
model DocumentSequence {
  id        String       @id @default(cuid())
  type      DocumentType
  year      Int
  counter   Int          @default(0)

  @@unique([type, year])
}

enum DeliveryMethod {
  email
  sms
  manual_download
}

enum DeliveryStatus {
  pending
  sent
  failed
}

// Trace des envois de documents (BL, BCol, Facture, Avoir) au client.
// Permet l'audit "a-t-on bien envoye le BL au client X le jour J ?"
model DocumentDelivery {
  id             String         @id @default(cuid())
  type           DocumentType
  number         String         // ex: "BL-2026-042"
  orderId        String?
  invoiceId      String?
  recipientEmail String
  recipientName  String?
  method         DeliveryMethod @default(email)
  status         DeliveryStatus @default(pending)
  errorMessage   String?
  sentAt         DateTime?
  attempt        Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([orderId])
  @@index([type, status])
  @@index([number])
}

// Identite de l'entreprise utilisee dans tous les PDFs (header + footer).
// Une seule ligne (singleton). Editable depuis le back-office.
model CompanySettings {
  id              String   @id @default(cuid())
  // Identite
  companyName     String
  legalForm       String?
  ninea           String?
  rcNumber        String?
  // Contact
  address         String
  city            String
  postalCode      String?
  country         String   @default("Senegal")
  phone           String?
  email           String?
  website         String?
  // Branding
  logoUrl         String?
  // Comptabilite
  vatRate         Decimal  @default(0.18) @db.Decimal(5, 4)
  bankName        String?
  bankAccount     String?
  bankSwift       String?
  // Mentions legales footer
  legalMentions   String?  @db.Text
  paymentTerms    String   @default("Paiement sous 30 jours")
  // Metadonnees
  updatedAt       DateTime @updatedAt
  updatedBy       String?
}

// ════════════ AVOIRS (CREDIT NOTES) ════════════

enum CreditNoteStatus {
  draft
  issued
  cancelled
}

// Avoir / note de credit. Genere en cas de litige (linge perdu, abime,
// surfacturation, etc.). Lie a une commande et/ou une facture.
model CreditNote {
  id              String           @id @default(cuid())
  number          String           @unique           // AV-YYYY-NNN
  orderId         String?
  invoiceId       String?
  clientId        String
  client          Client           @relation(fields: [clientId], references: [id])
  reason          String           @db.Text
  amountFcfa      Decimal          @db.Decimal(14, 2)
  status          CreditNoteStatus @default(draft)
  issuedAt        DateTime?
  pdfUrl          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdById     String?

  @@index([clientId])
  @@index([orderId])
}
